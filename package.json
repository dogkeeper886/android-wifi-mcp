{
  "name": "android-wifi-mcp",
  "version": "1.0.0",
  "description": "MCP Server for WiFi control on Android devices via ADB",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "android-wifi-shim": "./bin/android-wifi-shim.mjs"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test:unit": "node --test 'tests/unit/**/*.test.mjs'",
    "tools:count": "echo \"Native tools registered in src/server.ts: $(grep -c 'mcpServer\\.tool(' src/server.ts)\""
  },
  "keywords": [
    "mcp",
    "wifi",
    "android",
    "adb",
    "network"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.21.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
